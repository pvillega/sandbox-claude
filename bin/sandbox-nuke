#!/usr/bin/env bash
# sandbox-nuke
# Destroy ALL agent containers and golden images.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

require_sandbox

echo "This will destroy ALL agent containers, golden images, and deploy keys."
read -p "Are you sure? (yes/no): " CONFIRM
[[ "$CONFIRM" == "yes" ]] || { echo "Aborted"; exit 0; }

# Get list of containers before destroying them
CONTAINERS=$(vm_exec "incus list -f csv -c n 2>/dev/null | grep '^agent-'" || true)

for container in $CONTAINERS; do
  name="${container#agent-}"

  # Clean up SSH agent
  ssh_agent_cleanup "$container"

  # Clean up domain filtering (Squid ACL)
  cleanup_container_domain_filter "$container"

  # Clean up deploy key
  repo=$(get_metadata "$container" "repo")
  if [[ -n "$repo" ]]; then
    deploy_key_cleanup "$name" "$repo"
  fi

  # Clean up egress rules (FORWARD + NAT)
  container_ip=$(get_container_ip "$container")
  if [[ -n "$container_ip" ]]; then
    remove_container_squid_redirect "$container_ip"
    cleanup_container_forward_rules "$container_ip"
  fi

  info "Destroying ${container}..."
  vm_exec "incus delete '${container}' --force"
done

info "Destroying golden images..."
vm_exec "
  for g in \$(incus list -f csv -c n 2>/dev/null | grep '^golden-'); do
    echo \"Destroying \$g...\"
    incus delete \"\$g\" --force
  done
"
ok "Everything destroyed. Run 'sandbox-setup' to rebuild."

# Clean up any remaining local keys
if [[ -d "${SANDBOX_KEY_DIR}" ]]; then
  rm -rf "${SANDBOX_KEY_DIR}"
  info "Cleaned up local deploy keys"
fi
